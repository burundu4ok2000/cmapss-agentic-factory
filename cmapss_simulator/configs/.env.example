# ==========================================
# C-MAPSS Simulator Configuration (.env)
# ==========================================

# --- Physics Engine & Timing ---
TARGET_HZ=100
SIMULATION_EPOCH="2026-01-01T00:00:00Z"
FLIGHT_DURATION_MIN=120
FLIGHT_DURATION_MAX=300
AIRPORT_IDLE_MIN=15
AIRPORT_IDLE_MAX=30

# --- Storage & Export ---
COMPRESSION_LEVEL=1
DATA_OUTPUT_DIR="data/telemetry"
LOG_FILE_PATH="data/simulator.log"

# --- System Mode ---
# REALTIME (реальные секунды) или ACCELERATED (исторический якорь)
SIMULATION_MODE=REALTIME

# --- Dispatcher & Orchestration ---
WORKER_POOL_SIZE=100
BATCH_SIZE=100
FLUSH_INTERVAL_MS=100
UI_REFRESH_RATE_MS=1000

# --- CHAOS ENGINEERING (Morgoth's Forge) ---
# Допустимые значения: NONE, ORCS, BALROGS, SAURON, APOCALYPSE
# Или кастомный CSV список: "schema_rot, network_burst, time_drift, ..."
CHAOS_PROFILE="APOCALYPSE"