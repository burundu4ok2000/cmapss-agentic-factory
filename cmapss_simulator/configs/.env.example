# ==========================================
# C-MAPSS Simulator Configuration (Example)
# ==========================================

# --- Physics Engine ---
TARGET_HZ=100
SIMULATION_EPOCH="2026-01-01T00:00:00Z"

# --- Airport Timing (in seconds) ---
FLIGHT_DURATION_MIN=120
FLIGHT_DURATION_MAX=300
AIRPORT_IDLE_MIN=15
AIRPORT_IDLE_MAX=30

# --- Storage & Export ---
COMPRESSION_LEVEL=1

# --- System Mode ---
# REALTIME (реальные секунды, time.Now().UTC()) или ACCELERATED (исторический якорь)
SIMULATION_MODE=REALTIME

# --- Dispatcher & Buffer Tuning (Новые параметры) ---
# Размер каналов и батчей записи в базу данных
BATCH_SIZE=100
# Максимальное ожидание перед принудительным сбросом батча в БД (в миллисекундах)
FLUSH_INTERVAL_MS=100