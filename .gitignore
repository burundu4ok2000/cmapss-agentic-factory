# ==============================================================================
# 1. SECRETS & CREDENTIALS (КРИТИЧЕСКИ ВАЖНО)
# ==============================================================================
# Блокируем любые энвы, кроме шаблонного (он должен лететь в репозиторий)
.env
.env.*
!.env.example

# Ключи, сертификаты и локальные секреты
*.pem
*.key
*.rsa
secrets/

# ==============================================================================
# 2. PYTHON & ENVIRONMENT (uv / pip)
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class

# Виртуальные окружения (включая те, что создает uv)
.venv/
venv/
env/

# Кэши линтеров и тестов
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==============================================================================
# 3. GO & BUILD ARTIFACTS
# ==============================================================================
# Игнорируем скомпилированные бинарники (создай папку bin/ для локальных билдов)
cmapss_simulator/bin/
*.exe
*.out
*.test

# ==============================================================================
# 4. DATA, LOGS & TEMPORARY FILES
# ==============================================================================
*.tmp
*.log
*.sqlite3

# Строгий контракт для данных симулятора:
# Игнорируем весь сгенерированный мусор в data/, 
# но разрешаем трекинг эталонной директории cmapss_data/
cmapss_simulator/data/*
!cmapss_simulator/data/cmapss_data/

# ==============================================================================
# 5. OS & IDE (Кроссплатформенная гигиена)
# ==============================================================================
# macOS 
.DS_Store
.AppleDouble
.LSOverride

# Linux/Ubuntu (Сервер)
*~

# IDE
.idea/
.vscode/
*.swp

# ==============================================================================
# 6. Backups & Misc
# ==============================================================================

simulator_backup.txt

# ==============================================================================
# 6. terraform .gitignore pack (ref: https://github.com/github/gitignore/blob/main/Terraform.gitignore)
# ==============================================================================

# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: ignore graph output files generated by `terraform graph`
# *.dot

# Optional: ignore plan files saved before destroying Terraform configuration
# Uncomment the line below if you want to ignore planout files.
# planout