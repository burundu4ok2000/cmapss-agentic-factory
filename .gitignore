# ==============================================================================
# 1. SECRETS & CREDENTIALS (КРИТИЧЕСКИ ВАЖНО)
# ==============================================================================
# Блокируем любые энвы, кроме шаблонного (он должен лететь в репозиторий)
.env
.env.*
!.env.example

# Ключи, сертификаты и локальные секреты
*.pem
*.key
*.rsa
secrets/

# ==============================================================================
# 2. PYTHON & ENVIRONMENT (uv / pip)
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class

# Виртуальные окружения (включая те, что создает uv)
.venv/
venv/
env/

# Кэши линтеров и тестов
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ==============================================================================
# 3. GO & BUILD ARTIFACTS
# ==============================================================================
# Игнорируем скомпилированные бинарники (создай папку bin/ для локальных билдов)
cmapss_simulator/bin/
*.exe
*.out
*.test

# ==============================================================================
# 4. DATA, LOGS & TEMPORARY FILES
# ==============================================================================
*.tmp
*.log
*.sqlite3

# Строгий контракт для данных симулятора:
# Игнорируем весь сгенерированный мусор в data/, 
# но разрешаем трекинг эталонной директории cmapss_data/
cmapss_simulator/data/*
!cmapss_simulator/data/cmapss_data/

# ==============================================================================
# 5. OS & IDE (Кроссплатформенная гигиена)
# ==============================================================================
# macOS 
.DS_Store
.AppleDouble
.LSOverride

# Linux/Ubuntu (Сервер)
*~

# IDE
.idea/
.vscode/
*.swp